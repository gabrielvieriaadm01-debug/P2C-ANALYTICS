WITH CFOP_MAIS_RECURRENTE AS (

    SELECT
        RTRIM(DPBNOP) AS DPBNOP,
        RTRIM(DPBSOP) AS DPBSOP,
        DPBRNOP,

        ROW_NUMBER() OVER (
            PARTITION BY RTRIM(DPBNOP), RTRIM(DPBSOP)
            ORDER BY COUNT(*) DESC
        ) AS RN

    FROM JDE_PRODUCTION.PRODDTA.F76B200 

    GROUP BY
        RTRIM(DPBNOP),
        RTRIM(DPBSOP),
        DPBRNOP
)

SELECT 
    ZZ.SJDOCO AS 'Nº PEDIDO',
    LTRIM(RTRIM(SDLITM)) AS 'COD PRODUTO',
    ZZ.SJDCTO AS 'TIPO PEDIDO',
    ZZ.SJKCOO AS 'CIA',
    ZZ.SJSFXO AS 'SJSFXO',
    ZZ.SJLNID AS 'LINHA',
    ZZ.SJBNOP AS 'COD 1 CFOP',
    ZZ.SJBSOP AS 'COD 2 CFOP',

    CONCAT(
        RTRIM(ZZ.SJBNOP),
        '-',
        RTRIM(ZZ.SJBSOP)
    ) AS 'SUFIXO-CFOP',

    T1.SDKCO AS 'COD FISCAL',

    COALESCE(CF_EXATO.DPBRNOP, CF_FALLBACK.DPBRNOP) AS 'CFOP',

    DBO.FNC_JL_DATE(T1.SDTRDJ) AS 'DATA PEDIDO',

    CONCAT(ZZ.SJDOCO, ZZ.SJDCTO, ZZ.SJLNID, ZZ.SJKCOO) AS 'CHAVE'

FROM JDE_PRODUCTION.PRODDTA.F76422 ZZ

INNER JOIN JDE_PRODUCTION.PRODDTA.F4211 T1
    ON T1.SDDOCO = ZZ.SJDOCO
    AND T1.SDDCTO = ZZ.SJDCTO
    AND T1.SDKCOO = ZZ.SJKCOO
    AND T1.SDLNID = ZZ.SJLNID

-- TENTA MATCH EXATO
LEFT JOIN JDE_PRODUCTION.PRODDTA.F76B200 CF_EXATO 
    ON RTRIM(T1.SDKCO) = RTRIM(CF_EXATO.DPFCO)
    AND RTRIM(ZZ.SJBNOP) = RTRIM(CF_EXATO.DPBNOP)
    AND RTRIM(ZZ.SJBSOP) = RTRIM(CF_EXATO.DPBSOP)

-- FALLBACK MAIS RECORRENTE
LEFT JOIN CFOP_MAIS_RECURRENTE CF_FALLBACK
    ON RTRIM(ZZ.SJBNOP) = CF_FALLBACK.DPBNOP
    AND RTRIM(ZZ.SJBSOP) = CF_FALLBACK.DPBSOP
    AND CF_FALLBACK.RN = 1

WHERE 
    CONVERT(DATE, dbo.fnc_jl_date(SDTRDJ), 103) > '2026-04-01'
