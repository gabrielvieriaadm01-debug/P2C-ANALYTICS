SELECT 
    SDLNID AS 'LINHA',
    SDLNTY AS 'TIPO LINHA',
    SDNXTR AS 'CODIGO JDE',
    SDDOC AS 'DOC',
    SDDOCO AS 'N. PEDIDO', 
    SDOORN AS 'N. PEDIDO MÃE',
    SDDCTO AS 'TIPO PEDIDO',
    SDLTTR AS 'STATUS JDE',
    S.SHHOLD AS 'STATUS PEDIDO',
    SDUPC3 AS 'CLASSIFICACAO',

    LTRIM(RTRIM(SDMCU)) AS 'COD FABRICA',

    SDAN8 AS 'CLIFOR CLIENTE',
    F.ABALPH AS 'NOME CLIENTE',
    F.ABTAX AS 'CNPJ',
    F.ABTX2 AS 'IE',

    LTRIM(RTRIM(E.ALCTY1)) AS 'CIDADE',
    LTRIM(RTRIM(E.ALADDS)) AS 'UF',

    LTRIM(RTRIM(SDLITM)) AS 'COD PRODUTO',
    SDDSC1 AS 'DES PRODUTO',
    SDITM AS 'COD PRODUTO CHAVE',

    SDUORG / 10000 AS 'QUANT. PEDIDO',
    SDUOM AS 'UOM',

    (SDUORG / 10000) - (SDQTYT / 10000) AS 'QUANT. SALDO',

    SDUPRC / 10000 AS 'PRECO UNITARIO',
    SDAEXP / 100 AS 'VALOR PEDIDO',

    SDPTC AS 'COND PAGAMENTO',
    SDDELN AS 'NUMERO DE ENTREGA',

    SDVR01 AS 'ORDEM DE COMPRA',
    SDCARS AS 'TRANSPORTADORA',

    SDFRTH AS 'TIPO DE FRETE',
    SDUPC1 AS 'TIPO DE CARGA',
    SDUPC2 AS 'TIPO DE VEICULO',

    SDSLSM AS 'COD REPRESENTANTE',

    S.SHDEL1 AS 'OBSERVACOES 1',
    S.SHDEL2 AS 'OBSERVACOES 2',

    SDDOC AS 'NF',

    dbo.fnc_jl_date(SDTRDJ) AS 'PEDIDO DATE',
    dbo.fnc_jl_date(SDOPDJ) AS 'ENTREGA PROMETIDA DATE',
    dbo.fnc_jl_date(SDIVD) AS 'FAT DATE',

    (
        SELECT CAST(MAX(AIAC27) AS BIGINT)
        FROM PRODDTA.F03012 P WITH (NOLOCK)
        WHERE
            P.AIAN8 = C.SDAN8
            AND P.AIAC27 BETWEEN 401 AND 527
            AND C.SDCO = P.AICO
    ) AS 'AREA COMERCIAL'

FROM PRODDTA.F4211 C WITH (NOLOCK)

INNER JOIN PRODDTA.F0116 E WITH (NOLOCK)
    ON E.ALAN8 = C.SDAN8

INNER JOIN PRODDTA.F4201 S WITH (NOLOCK)
    ON S.SHAN8 = C.SDAN8
    AND S.SHMCU = C.SDMCU
    AND S.SHDOCO = C.SDDOCO

INNER JOIN PRODDTA.F0101 F WITH (NOLOCK)
    ON F.ABAN8 = C.SDAN8

LEFT JOIN PRODDTA.F4941 R WITH (NOLOCK)
    ON R.RSSHPN = C.SDDELN
    AND C.SDDELN <> 0

-- ✅ Schema corrigido: PRODCTL.F0005
LEFT JOIN PRODCTL.F0005 UDC WITH (NOLOCK)
    ON UDC.DRSY = '40'
    AND UDC.DRRT = 'AT'
    AND UDC.DRKY = LTRIM(RTRIM(CAST(C.SDLTTR AS VARCHAR(10))))

WHERE
    SDDCTO NOT IN ('LO','LX','VS','VU','VT','VY')
    AND SDLNTY NOT IN ('ML','BX','DS','MW')

    AND CONVERT(DATE, dbo.fnc_jl_date(SDTRDJ), 103) >= '2026-04-01'
    AND CONVERT(DATE, dbo.fnc_jl_date(SDTRDJ), 103) < '2026-05-01'
